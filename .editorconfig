root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{json,json5}]
indent_size = 2

[*.xml]
indent_size = 2

[*.{kt,kts}]
ktlint_code_style = intellij_idea
max_line_length = 120
ktlint_standard_no-wildcard-imports = disabled

[composeApp/**/*.{kt,kts}]
ktlint_function_naming_ignore_when_annotated_with = Composable
# Compose rules (io.nlopez.compose.rules) — only enforced in the composeApp module
compose_check_modifiers_for_visibility = public_and_internal
compose_disallow_material2 = true
compose_preview_naming_enabled = true
compose_preview_naming_strategy = suffix

[{**Test.kt,**Tests.kt,**TestCase.kt,**Fake*.kt,**Mock*.kt}]
max_line_length = off
ktlint_standard_function-naming = disabled
